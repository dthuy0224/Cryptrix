# ==============================================================================
# Cryptrix — Environment Variables
# ==============================================================================
# Copy to .env and fill in your values. Never commit .env to git.
# ==============================================================================

# --- Environment ---
ENVIRONMENT=development   # development | staging | production
PROJECT_NAME=Cryptrix
LOG_LEVEL=INFO

# --- PostgreSQL ---
POSTGRES_USER=cryptrix_admin
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=cryptrix_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://cryptrix_admin:your_strong_password_here@localhost:5432/cryptrix_db

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
REDIS_URL=redis://:your_redis_password_here@localhost:6379/0

# --- FastAPI ---
API_PORT=8000
CORS_ORIGINS=["http://localhost:8501", "http://localhost:3000"]

# --- Streamlit Dashboard ---
DASHBOARD_PORT=8501
API_BASE_URL=http://localhost:8000/api/v1

# --- MLflow ---
MLFLOW_PORT=5000
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=cryptrix-market-forecasting
MLFLOW_ARTIFACT_URI=gs://cryptrix-ml-artifacts/models/   # GCS (optional)

# --- Binance API (optional for public endpoints) ---
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# --- CoinGecko API (optional — free tier works without key) ---
COINGECKO_PRO_API_KEY=your_coingecko_key_here

# --- Sentiment APIs (optional — mock data used if absent) ---
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here
NEWS_API_KEY=your_news_api_key_here

# --- GCP (optional — for cloud deployment) ---
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGIONAL_ZONE=us-central1
GCLOUD_CREDENTIALS_JSON_PATH=/path/to/gcp/key.json
GCS_RAW_DATA_BUCKET=cryptrix-raw-data-lake
GCS_SILVER_DATA_BUCKET=cryptrix-silver-transformed
BIGQUERY_ANALYTICS_DATASET=cryptrix_analytics

# --- Airflow ---
AIRFLOW_IMAGE_NAME=apache/airflow:2.9.1-python3.11
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://cryptrix_admin:your_strong_password_here@localhost:5432/cryptrix_airflow

# --- Kafka (Phase 5 — Advanced) ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_MARKET_TICKERS=cryptrix.market.tickers
KAFKA_TOPIC_PREDICTIONS=cryptrix.ml.predictions
