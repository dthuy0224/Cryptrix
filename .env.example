# ==============================================================================
# Cryptrix Consolidated Environment Variables Template
# ==============================================================================
# Copy this file to .env and adjust variables as required for local/prod runs.

# ------------------------------------------------------------------------------
# Global Infrastructure Settings
# ------------------------------------------------------------------------------
ENVIRONMENT=development # development | staging | production
PROJECT_NAME=Cryptrix
LOG_LEVEL=INFO

# ------------------------------------------------------------------------------
# PostgreSQL Configuration (Application DB)
# ------------------------------------------------------------------------------
POSTGRES_USER=cryptrix_admin
POSTGRES_PASSWORD=cryptrix_secure_password_123
POSTGRES_DB=cryptrix_app
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://cryptrix_admin:cryptrix_secure_password_123@localhost:5432/cryptrix_app

# ------------------------------------------------------------------------------
# Redis Configuration (Caching & Realtime WebSocket PubSub)
# ------------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secure_password_123
REDIS_URL=redis://:redis_secure_password_123@localhost:6379/0

# ------------------------------------------------------------------------------
# FastAPI Backend Configuration
# ------------------------------------------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SECRET_KEY=cryptrix_jwt_signing_secret_key_change_me_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=11520
CORS_ORIGINS=["http://localhost:3000", "https://cryptrix.example.com"]

# ------------------------------------------------------------------------------
# Next.js Frontend Configuration
# ------------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/api/v1/market/ws

# ------------------------------------------------------------------------------
# GCP & BigQuery Configuration
# ------------------------------------------------------------------------------
GCP_PROJECT_ID=cryptrix-production-42
GCP_REGIONAL_ZONE=us-central1
GCLOUD_CREDENTIALS_JSON_PATH=/path/to/gcp/key.json
GCS_RAW_DATA_BUCKET=cryptrix-raw-data-lake
GCS_SILVER_DATA_BUCKET=cryptrix-silver-transformed
BIGQUERY_ANALYTICS_DATASET=cryptrix_analytics

# ------------------------------------------------------------------------------
# Apache Airflow Configuration
# ------------------------------------------------------------------------------
AIRFLOW_IMAGE_NAME=apache/airflow:2.9.1-python3.11
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://cryptrix_admin:cryptrix_secure_password_123@localhost:5432/cryptrix_airflow

# ------------------------------------------------------------------------------
# MLOps & MLflow Configuration
# ------------------------------------------------------------------------------
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_ARTIFACT_URI=gs://cryptrix-ml-artifacts/models/
MLFLOW_EXPERIMENT_NAME=cryptrix-market-forecasting

# ------------------------------------------------------------------------------
# Third-Party Market Data APIs (Obtain Keys from Providers)
# ------------------------------------------------------------------------------
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
COINGECKO_PRO_API_KEY=your_coingecko_api_key_here
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here
NEWS_API_KEY=your_news_api_key_here

# ------------------------------------------------------------------------------
# Future Message Broker Configuration (Kafka Placeholders)
# ------------------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_MARKET_TICKERS=cryptrix.market.tickers
KAFKA_TOPIC_PREDICTIONS=cryptrix.ml.predictions
KAFKA_TOPIC_WHALE_ALERTS=cryptrix.chain.whales
